# ---------------------------------------------------------------------------
# Environment for the next-candle prediction dashboard.
# Copy to .env on the server:  cp .env.example .env  (then edit)
# The app reads this file automatically (python-dotenv) from its working dir.
# NEVER commit a real .env — it is git-ignored by convention.
# ---------------------------------------------------------------------------

# Public URL (documentation / reference only; the app serves relative paths)
APP_URL=https://tradebotvol.com

# Port the dashboard listens on internally (behind Nginx). Nginx proxies to it.
PORT=8080

# Not used by this Python app; included for tooling compatibility only.
NODE_ENV=production

# ---- Dashboard login (HTTP Basic auth) ------------------------------------
# Leave BOTH blank to keep the dashboard open (local development).
# Set BOTH to require a username + password before the dashboard and before any
# state-changing control route (pause / resume / restart / clear / shutdown /
# settings). Generate the hash with:
#     python dashboard.py --hash-password "your-strong-password"
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=

# PUBLIC_VIEW=true  -> anyone can VIEW the dashboard with no password, but the
# control buttons (pause / clear / shutdown / settings) still require the login
# above. Leave blank/false to also require login just to view.
PUBLIC_VIEW=

# ---- Binance API credentials (OPTIONAL) -----------------------------------
# Public market data needs no key; leave empty.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ---- Binance TESTNET keys (for trade_testnet.py --live-testnet) -----------
# FAKE MONEY ONLY. Create free keys at https://testnet.binancefuture.com
# (log in with GitHub/Google -> API Key). These carry NO real funds and the
# bot is hard-locked to the testnet endpoint. NEVER put real-account keys here.
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# Optional console log level override (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
